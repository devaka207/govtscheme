          "mode": "Offline",
          "process": [
            {
              "type": "align_justify",
              "children": [
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "The vaccination facility is available to the entire community free of cost at government health institutions, including health centres, sub-centres, post-natal centres, and urban health centres. All children aged 0–16 years can avail of these benefits by registering for vaccination."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "For registration, the child must be taken to the concerned government hospital, and the birth certificate or card issued by the ANM is required."
                    }
                  ]
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": ""
                }
