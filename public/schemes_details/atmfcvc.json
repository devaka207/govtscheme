      "applicationProcess": [
        {
          "mode": "Online",
          "process": [
            {
              "type": "align_justify",
              "children": [
                {
                  "type": "align_justify",
                  "children": [
                    {
                      "type": "block_quote",
                      "children": [
                        {
                          "text": "Registration Process:",
                          "bold": true
                        }
                      ]
                    },
                    {
                      "type": "paragraph",
                      "children": [
                        {
                          "text": "Step 1: ",
                          "bold": true
                        },
                        {
                          "text": "The applicant may visit and apply online at the "
                        },
                        {
                          "type": "link",
                          "link": "https://ikhedut.gujarat.gov.in/",
                          "children": [
                            {
                              "text": "I-Khedut"
                            }
                          ]
                        },
                        {
                          "text": " Portal."
                        }
                      ]
                    },
                    {
                      "type": "paragraph",
                      "children": [
                        {
                          "text": "Step 2:",
                          "bold": true
                        },
                        {
                          "text": " Click on 'Login' from the top right-hand side, then click on \"Beneficiary Registration\" and select any one from the 'Farmer' or 'Institutional' or 'Except For the Farmer' as the Beneficiary Type."
                        }
                      ]
                    },
                    {
                      "type": "paragraph",
                      "children": [
                        {
                          "text": "Step 3:",
                          "bold": true
                        },
                        {
                          "text": " Select the District, Taluka, and Village, choose 'what type of account holder you are?', enter your Account Number and Name, solve the Captcha, and click 'Save and Next'."
                        }
                      ]
                    },
                    {
                      "type": "paragraph",
                      "children": [
                        {
                          "text": "Step 4:",
                          "bold": true
                        },
                        {
                          "text": " Enter your Mobile Number and Email address, click 'Send OTP', enter the received OTP, create and confirm a Password, solve the Captcha, and click 'Submit'."
                        }
                      ]
                    },
                    {
                      "type": "block_quote",
                      "children": [
                        {
                          "text": "Login Process:",
                          "bold": true
                        },
                        {
                          "text": " "
                        }
                      ]
                    },
                    {
                      "type": "paragraph",
                      "children": [
                        {
                          "text": "Step 1:",
                          "bold": true
                        },
                        {
                          "text": " The applicant may visit and apply online at the "
                        },
                        {
                          "type": "link",
                          "link": "https://ikhedut.gujarat.gov.in/site/",
                          "children": [
                            {
                              "text": "I-Khedut"
                            }
                          ]
                        },
                        {
                          "text": " Portal."
                        }
                      ]
                    },
                    {
                      "type": "paragraph",
                      "children": [
                        {
                          "text": "Step 2:",
                          "bold": true
                        },
                        {
                          "text": " Click on 'Login' from the top right-hand side of the homepage. On the home page, click on ‘Schemes’ and then click on ‘Agricultural Schemes’."
                        }
                      ]
                    },
                    {
                      "type": "paragraph",
                      "children": [
                        {
                          "text": "Step 3:",
                          "bold": true
                        },
                        {
                          "text": " Now select the scheme, click on the ‘Apply’ button, and an application page will open."
                        }
                      ]
                    },
                    {
                      "type": "paragraph",
                      "children": [
                        {
                          "text": "Step 4:",
                          "bold": true
                        },
                        {
                          "text": " Click on the \"Apply New\" button and submit a new application."
                        }
                      ]
                    },
                    {
                      "type": "paragraph",
                      "children": [
                        {
                          "text": "Step 5:",
                          "bold": true
                        },
                        {
                          "text": " Click on the \"Update Application\" button to add corrections to the application."
                        }
                      ]
                    },
                    {
                      "type": "paragraph",
                      "children": [
                        {
                          "text": "Step 6:",
                          "bold": true
                        },
                        {
                          "text": " Once the application is done, confirm it."
