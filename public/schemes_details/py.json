        "schemeImageUrl": "",
        "briefDescription": "This scheme provides financial assistance to Scheduled Tribe students who have passed national competitive examinations such as JEE, NEET, CLAT, AIIMS, and NDA, and have taken admission in IIT, NIT, NLU, MBBS (government colleges located in Madhya Pradesh), AIIMS or NDA.",
        "detailedDescription_md": "The &amp;quot;Pratibha Yojana&amp;quot; was launched by the Tribal Affairs Department, Government of Madhya Pradesh on 01.09.2016 to encourage talented students of the Scheduled Tribe Category for higher education. This scheme provides financial assistance to Scheduled Tribe students who have passed national competitive examinations such as JEE, NEET, CLAT, AIIMS, &amp;amp; NDA and have taken admission in IIT, NIT, NLU, MBBS (government colleges located in Madhya Pradesh), AIIMS or NDA.\n",
        "benefits_md": "Under this scheme, eligible students are provided with the following incentives:\n\n  - A financial assistance of ₹50,000/- is provided to students whose annual parental income is up to ₹3,00,000/-.\n  - A financial assistance of ₹25,000/- is provided to students whose annual parental income exceeds ₹3,00,000/-.\n\n**Note:** The incentive amount is paid into the applicant’s bank account linked to Aadhaar.\n",
        "exclusions_md": "",
        "detailedDescription": [
          {
            "type": "align_justify",
            "children": [
              {
                "type": "paragraph",
                "children": [
                  {
                    "text": "The \"Pratibha Yojana\" was launched by the Tribal Affairs Department, Government of Madhya Pradesh on 01.09.2016 to encourage talented students of the Scheduled Tribe Category for higher education. This scheme provides financial assistance to Scheduled Tribe students who have passed national competitive examinations such as JEE, NEET, CLAT, AIIMS, & NDA and have taken admission in IIT, NIT, NLU, MBBS (government colleges located in Madhya Pradesh), AIIMS or NDA."
                  }
                ]
              }
            ]
          }
        ],
        "benefitTypes": {
          "id": 1,
          "value": "cash",
          "label": "Cash"
        },
        "benefits": [
          {
            "type": "align_justify",
            "children": [
              {
                "type": "paragraph",
                "children": [
                  {
                    "text": "Under this scheme, eligible students are provided with the following incentives:"
                  }
                ]
              },
              {
                "type": "ul_list",
                "children": [
                  {
                    "type": "list_item",
                    "children": [
                      {
                        "text": "A financial assistance of ₹50,000/- is provided to students whose annual parental income is up to ₹3,00,000/-."
                      }
                    ]
                  },
                  {
                    "type": "list_item",
                    "children": [
                      {
                        "text": "A financial assistance of ₹25,000/- is provided to students whose annual parental income exceeds ₹3,00,000/-."
                      }
                    ]
                  }
                ]
              },
              {
                "type": "paragraph",
                "children": [
                  {
                    "text": "Note:",
                    "bold": true
                  },
                  {
                    "text": " The incentive amount is paid into the applicant’s bank account linked to Aadhaar."
                  }
                ]
              }
            ]
          }
        ]
      },
