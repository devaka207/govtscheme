                "children": [
                  {
                    "type": "list_item",
                    "children": [
                      {
                        "text": "To reduce the burden of high expenditure on cancer patients."
                      }
                    ]
                  },
                  {
                    "type": "list_item",
                    "children": [
                      {
                        "text": "To provide free chemotherapy for all types of cancer at any stage."
                      }
                    ]
                  }
                ]
              },
              {
                "type": "paragraph",
                "children": [
                  {
                    "text": "Important Features:",
                    "bold": true
