      "applicationProcess": [
        {
          "mode": "Online",
          "process": [
            {
              "type": "block_quote",
              "children": [
                {
                  "text": "Registration:",
                  "bold": true,
                  "underline": true
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "bold": true,
                  "text": "Step 1: "
                },
                {
                  "text": "Visit the official ESDM Skill Development portal: "
                },
                {
                  "type": "link",
                  "link": "https://esdm-skill.deity.gov.in",
                  "children": [
                    {
                      "text": "https://esdm-skill.deity.gov.in."
                    }
                  ]
                },
                {
                  "text": ""
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 2: ",
                  "bold": true
                },
                {
                  "text": "Identify the nearest affiliated Training Partner (TP) through the portal or authorised sources."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 3: ",
                  "bold": true
                },
                {
                  "text": "Approach the Training Partner for counselling and selection of the appropriate NSQF course."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 4: ",
                  "bold": true
                },
                {
                  "text": "Submit required documents and eligibility details to the Training Partner."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 5: ",
                  "bold": true
                },
                {
                  "text": "Provide Aadhaar Number or Aadhaar Enrolment ID and complete Aadhaar authentication / e-KYC (with consent)."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 6: ",
                  "bold": true
                },
                {
                  "text": "Fill the application/enrolment form at the Training Partner centre or through the portal."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 7: ",
                  "bold": true
                },
                {
                  "text": "Pay the Registration-cum-Certification Fee (RCCF) to the Training Partner."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 8: ",
                  "bold": true
                },
                {
                  "text": "Submit required undertakings:"
                }
              ]
            },
            {
              "type": "ul_list",
              "children": [
                {
                  "type": "list_item",
                  "children": [
                    {
                      "text": "Undertaking for the non-availability of a similar Government scheme"
                    }
                  ]
                },
                {
                  "type": "list_item",
                  "children": [
                    {
                      "text": "Undertaking for willingness for employment/self-employment"
                    }
                  ]
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 9:",
                  "bold": true
                },
                {
                  "text": "The Training Partner verifies eligibility and completes enrolment of the applicant."
                }
              ]
            },
            {
              "type": "block_quote",
              "children": [
                {
                  "text": "After Registration:",
                  "bold": true,
                  "underline": true
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "bold": true,
                  "text": "Step 1: "
                },
                {
                  "text": "The applicant undergoes training for the prescribed duration as per the selected NSQF course."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 2: ",
                  "bold": true
                },
                {
                  "text": "The applicant maintains the required attendance (minimum 70%) during training."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 3: ",
                  "bold": true
                },
                {
                  "text": "The applicant appears for assessment conducted by the respective Key Implementing Agency (KIA)."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 4: ",
                  "bold": true
                },
                {
                  "text": "Upon successful assessment, the applicant receives certification."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 5: ",
                  "bold": true
                },
                {
                  "text": "The Training Partner facilitates placement or supports self-employment opportunities."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 6: ",
                  "bold": true
                },
                {
                  "text": "Placement of the candidate is tracked for a minimum period of 3 months."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 7: ",
                  "bold": true
                },
                {
                  "text": "Financial reimbursement is processed:"
                }
              ]
            },
            {
              "type": "ul_list",
              "children": [
                {
                  "type": "list_item",
                  "children": [
                    {
                      "text": "First instalment after certification"
                    }
                  ]
                },
                {
                  "type": "list_item",
                  "children": [
                    {
                      "text": "Second instalment after successful placement"
                    }
                  ]
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": ""
                }
              ]
            }
          ],
          "process_md": "> **Registration:**\n\n**Step 1:** Visit the official ESDM Skill Development portal: [https://esdm-skill.deity.gov.in.](https://esdm-skill.deity.gov.in)\n**Step 2:** Identify the nearest affiliated Training Partner (TP) through the portal or authorised sources.\n**Step 3:** Approach the Training Partner for counselling and selection of the appropriate NSQF course.\n**Step 4:** Submit required documents and eligibility details to the Training Partner.\n**Step 5:** Provide Aadhaar Number or Aadhaar Enrolment ID and complete Aadhaar authentication / e-KYC (with consent).\n**Step 6:** Fill the application/enrolment form at the Training Partner centre or through the portal.\n**Step 7:** Pay the Registration-cum-Certification Fee (RCCF) to the Training Partner.\n**Step 8:** Submit required undertakings:\n\n- Undertaking for the non-availability of a similar Government scheme\n- Undertaking for willingness for employment/self-employment\n\n**Step 9:**The Training Partner verifies eligibility and completes enrolment of the applicant.\n> **After Registration:**\n\n**Step 1:** The applicant undergoes training for the prescribed duration as per the selected NSQF course.\n**Step 2:** The applicant maintains the required attendance (minimum 70%) during training.\n**Step 3:** The applicant appears for assessment conducted by the respective Key Implementing Agency (KIA).\n**Step 4:** Upon successful assessment, the applicant receives certification.\n**Step 5:** The Training Partner facilitates placement or supports self-employment opportunities.\n**Step 6:** Placement of the candidate is tracked for a minimum period of 3 months.\n**Step 7:** Financial reimbursement is processed:\n\n- First instalment after certification\n- Second instalment after successful placement\n\n<br>\n\n"
        }
      ],
      "schemeDefinitions": [],
      "eligibilityCriteria": {
        "eligibilityDescription_md": "\n1. The applicant should be studying in Class 9 or Class 10 onwards; or the applicant should be a school dropout from 8th pass onwards; or the applicant should be an ITI certificate holder, a diploma holder, an undergraduate, a graduate, or registered in employment exchanges.\n1. The applicant should be eligible to enrol in any of the 5 NSQF levels (Level 1 to Level 5), subject to meeting the minimum eligibility criteria of the respective course.\n1. The applicant should have a valid Aadhaar Number, or an Aadhaar Enrolment ID (EID) may also be considered.\n1. The applicant should provide consent for Aadhaar authentication or the e-KYC process.\n1. The applicant should not have been a beneficiary of any Government of India-aided skilling course in the ESDM field, sponsored by the Central or State Government.\n1. The applicant should submit an undertaking declaring non-availment of any such scheme at the time of enrolment.\n1. The applicant should have attained a minimum age of 17 years at the time of registration/enrolment.\n1. The applicant should be willing to get employed or self-employed and submit an undertaking to this effect at the time of enrolment.\n1. The applicant should undergo training for the prescribed duration and appear for an assessment conducted by the respective Key Implementing Agency (KIA).\n1. The applicant should maintain at least 70% attendance to be eligible to appear for the assessment.\n1. The applicant can avail the benefit under the scheme only once; however, for manufacturing job roles, the applicant may be allowed to undergo two courses at successive NSQF levels.\n\n> **Reservation / Preference:**\n\n\n- 60% seats: General Category\n- 40% seats: Reserved Categories\n\n  - SC: 15%\n  - ST: 7.5%\n  - EWS: 17.5%\n\n- EWS Criteria:\n\n  - The applicant’s family income should not exceed ₹2,00,000/- annually.\n\n\n<br>\n\n",
