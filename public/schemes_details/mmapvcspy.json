                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 1:",
                      "bold": true
                    },
                    {
                      "text": " Visit the "
                    },
                    {
                      "type": "link",
                      "link": "https://bcebconline.bihar.gov.in/cspy/EBCscholarship/Index.aspx",
                      "children": [
                        {
                          "text": "official website",
                          "bold": true
                        }
                      ]
                    },
                    {
                      "text": ". Click \""
                    },
                    {
                      "type": "link",
                      "link": "https://bcebconline.bihar.gov.in/cspy/EBCscholarship/PETC_Terms.aspx",
                      "children": [
                        {
                          "text": "New Registration",
                          "bold": true
                        }
                      ]
                    },
                    {
                      "text": "\" option, in case of a new applicant. "
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 2: ",
                      "bold": true
                    },
                    {
                      "text": "In case of "
                    },
                    {
                      "bold": true,
                      "text": "\"New Registration\" "
                    },
                    {
                      "text": "carefully read the \"Guidelines for Registration\" and click \"Continue.\""
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 3: ",
                      "bold": true
                    },
                    {
                      "text": "On successful login"
                    },
                    {
                      "bold": true,
                      "text": ", "
                    },
                    {
                      "text": "enter the form by entering your personal details, educational qualifications, and other required information."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 4:",
                      "bold": true
                    },
                    {
                      "text": " Upload your photograph, signature, and any necessary documents."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 5: ",
                      "bold": true
                    },
                    {
                      "text": "Ensure all fields marked with an asterisk (*) are filled in correctly."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 6:",
                      "bold": true
                    },
                    {
                      "text": " Once all the required information is entered, click the \"Submit\" button. Upon successful submission, you will receive a registration ID and password."
                    }
                  ]
                },
                {
                  "type": "block_quote",
                  "children": [
                    {
                      "text": "Process to apply for scheme:",
                      "bold": true,
                      "underline": true
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 1: ",
                      "bold": true
                    },
                    {
                      "text": "In case already registered, then click on \""
                    },
                    {
                      "text": "A",
                      "bold": true
                    },
                    {
                      "type": "link",
                      "link": "https://bcebconline.bihar.gov.in/cspy/EBCscholarship/Login.aspx",
                      "children": [
                        {
                          "text": "pplicant Login",
                          "bold": true
                        }
                      ]
                    },
                    {
                      "text": "\" option. "
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 2:",
                      "bold": true
                    },
                    {
                      "text": " Enter your User ID, Password, and the verification code."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 3: ",
                      "bold": true
                    },
                    {
                      "text": "Click \"Login\" to access your account and fill out the application form."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 4: ",
                      "bold": true
                    },
                    {
                      "text": "Verify your entries before submitting the application. No modifications can be made after the final submission."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 5:",
                      "bold": true
                    },
                    {
                      "text": " After verifying your application form, click \"Submit\" to save your application."
                    }
                  ]
                },
                {
                  "type": "ul_list",
                  "children": [
                    {
                      "type": "list_item",
                      "children": [
                        {
                          "text": "You may print the application form as a draft."
                        }
                      ]
                    },
                    {
                      "type": "list_item",
                      "children": [
                        {
                          "text": "An application ID will be generated after the final submission."
                        }
                      ]
                    },
                    {
                      "type": "list_item",
                      "children": [
                        {
                          "text": "Only the final submission will be considered."
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 6:",
                      "bold": true
                    },
                    {
                      "text": " Print a copy of the finally submitted application form."
                    }
