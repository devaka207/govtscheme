      "schemeDefinitions": [],
      "eligibilityCriteria": {
        "eligibilityDescription_md": "\n1. Applicant must be a widow women from Rajasthan State.\n1. Applicant must be resident of Rajasthan or living in Rajasthan for 3 years before re-marriage.\n1. Applicant should be entitled to pension as per widow pension rules.\n1. Applicant age should be between 18-50 years.\n1. If the applicant has remarried before this scheme then he/she will not be eligible.\n\n",
