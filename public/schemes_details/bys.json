            ]
          },
          {
            "type": "ol_list",
            "children": [
              {
                "type": "list_item",
                "children": [
                  {
                    "text": "A scholarship of Rs.300 per annum for girls in classes 1st to 3rd"
                  }
                ]
              },
              {
                "type": "list_item",
                "children": [
                  {
                    "text": "A scholarship of Rs.500 per annum for girls in classes 4th"
                  }
                ]
              },
              {
                "type": "list_item",
                "children": [
                  {
                    "text": "A scholarship of Rs.600 per annum for girls in classes 5th"
                  }
                ]
              },
              {
                "type": "list_item",
                "children": [
                  {
                    "text": "A scholarship of Rs.700 per annum for girls in classes 6th and 7th"
                  }
                ]
              },
              {
                "type": "list_item",
                "children": [
                  {
                    "text": "A scholarship of Rs.800 per annum for girls in classes 8th"
                  }
                ]
              },
              {
                "type": "list_item",
