        "schemeImageUrl": "",
        "briefDescription": "The prime goal of this scheme aims to promote the birth of girl children in below poverty line(BPL) families and to raise the status of the girl child in the family in particular and society in general. Financial assistance is provided to the girl child through her mother/father or natural guardian.",
        "detailedDescription": [
          {
            "type": "paragraph",
            "children": [
              {
                "text": "Detail",
                "bold": true
              }
            ]
          },
          {
            "type": "paragraph",
            "children": [
              {
                "text": "The Karnataka state government will give female children financial aid under the Karnataka Bhagya Lakshmi Scheme. The payment of this support is to be made through the mother, father, or legal guardian provided that all requirements are met. "
              }
            ]
          },
          {
            "type": "paragraph",
            "children": [
              {
                "text": "",
                "bold": true
              }
            ]
          },
          {
            "type": "paragraph",
            "children": [
              {
                "bold": true,
                "text": "The objective of this scheme"
              }
            ]
          },
          {
            "type": "ul_list",
            "children": [
              {
                "type": "list_item",
                "children": [
                  {
                    "text": "To promote the birth of girl children among families identified as below the poverty line."
                  }
                ]
              },
              {
                "type": "list_item",
                "children": [
                  {
                    "text": "To increase the status of girl child thereby raising the status of the society."
                  }
                ]
              },
              {
                "type": "list_item",
                "children": [
                  {
                    "text": "To Promote the birth of girl child in economically weaker families and to raise their status within the family and society."
                  }
                ]
              },
              {
                "type": "list_item",
                "children": [
                  {
                    "text": "To provide Financial assistance to the girl child through her mother/father/natural guardian subject to the fulfilment of certain conditions"
                  }
                ]
              }
            ]
          },
          {
            "type": "paragraph",
            "children": [
              {
                "text": ""
              }
            ]
