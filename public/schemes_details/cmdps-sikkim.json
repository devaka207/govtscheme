        "schemeImageUrl": "",
        "briefDescription": "The scheme “Chief Minister's State Disability Pension Scheme (CMDPS)” was started by the Women & Child Welfare Department, Govt. of Sikkim to provide financial assistance to the differently abled person who has a disability of 40% and above. ",
        "detailedDescription": [
          {
            "type": "align_justify",
            "children": [
              {
                "type": "paragraph",
                "children": [
                  {
                    "text": "The scheme “Chief Minister's State Disability Pension Scheme (CMDPS)” was started by the Women & Child Welfare Department, Govt. of Sikkim to provide financial assistance to the differently abled person who has a disability of 40% and above. This scheme is 100% State Innovative Scheme and the beneficiary will receive a monthly pension of ₹ 1500/-."
                  }
                ]
              }
            ]
          }
        ],
        "benefitTypes": {
