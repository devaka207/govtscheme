        "schemeImageUrl": "https://sw.kar.nic.in/swincentive/dvds/dvdshome.aspx",
        "briefDescription": "Under this scheme, the Social Welfare Department, Government of Karnataka will give incentives of ₹3.00 lakh for men,₹5.00 lakh for women to the Devadasi's Children who are Married Couples.",
        "detailedDescription": [
          {
            "type": "paragraph",
            "children": [
              {
                "text": "Under this scheme, the Social Welfare Department, Government of Karnataka will give incentives to the Devadasi's Children's Married Couple."
              }
            ]
          },
          {
            "type": "paragraph",
            "children": [
              {
                "text": "To avail this scheme, both bride and groom should belong to SC Community. "
              }
            ]
          },
          {
            "type": "paragraph",
            "children": [
              {
                "text": "The incentive will be provided only to those who have submitted applications within 1.5 years (18 months) of marriage. "
              }
            ]
          },
          {
            "type": "paragraph",
            "children": [
              {
                "text": "The couple who are married on or after 01-04-2018 are eligible for a revised rate of incentive (i.e. 3.00 lakh for men, 5.00 lakh for women)"
              }
            ]
          },
          {
            "type": "paragraph",
            "children": [
              {
                "text": "The annual family income of the applicant should be below Rs.5,00,000/-"
              }
            ]
          },
          {
            "type": "paragraph",
            "children": [
              {
                "text": ""
              }
            ]
          },
          {
            "type": "paragraph",
            "children": [
              {
                "text": "The following are the eligibility criteria for this scheme "
              }
            ]
          },
          {
            "type": "ul_list",
            "children": [
              {
                "type": "list_item",
                "children": [
                  {
                    "text": "Applicant should be a resident of Karnataka state."
                  }
                ]
              },
              {
                "type": "list_item",
                "children": [
                  {
                    "text": "Applicant should belong to the  SC community."
                  }
                ]
              },
              {
                "type": "list_item",
                "children": [
                  {
                    "text": "Family income from all sources should be within Rs. 5 lakhs per annum."
                  }
                ]
