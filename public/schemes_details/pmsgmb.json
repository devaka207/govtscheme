      "applicationProcess": [
        {
          "mode": "Online",
          "process": [
            {
              "type": "align_justify",
              "children": [
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step-1",
                      "bold": true
                    },
                    {
                      "text": " : Visit the "
                    },
                    {
                      "type": "link",
                      "link": "https://pmsuryaghar.gov.in/#/",
                      "children": [
                        {
                          "text": "official website"
                        }
                      ]
                    },
                    {
                      "text": "."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step-2",
                      "bold": true
                    },
                    {
                      "text": " : Provide the following details for registration."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "            - Select your State"
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "            - Select your Electricity Distribution Company"
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "            - Enter your Electricity Consumer Number"
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "            - Enter Mobile Number"
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "            - Enter Email"
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "            - Please follow as per the direction from the portal."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step-3",
                      "bold": true
                    },
                    {
                      "text": " : Login with Consumer Number & Mobile Number."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step-4 ",
                      "bold": true
                    },
                    {
                      "text": ": Apply for the Rooftop Solar as per the form."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step-5 ",
                      "bold": true
                    },
                    {
                      "text": ": Fill out the online application form."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step-6 ",
                      "bold": true
                    },
                    {
                      "text": ": Wait for the feasibility approval from DISCOM. Once you get the feasibility approval install the plant by any of the registered vendors in your DISCOM."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step-7 ",
                      "bold": true
                    },
                    {
                      "text": ": Once installation is over, submit the plant details and apply for net meter."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step-8 ",
                      "bold": true
                    },
                    {
                      "text": ": After installation of net meter and inspection by DISCOM, they will generate commissioning certificate from portal."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step-9",
                      "bold": true
                    },
                    {
                      "text": " : Once you get the commissioning report. Submit the bank account details and a cancelled cheque through the portal. You will receive your subsidy in your bank account within 30 days. "
                    }
                  ]
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": ""
                }
              ]
            }
          ],
          "process_md": "**Step-1** : Visit the [official website](https://pmsuryaghar.gov.in/#/).\n**Step-2** : Provide the following details for registration.\n            - Select your State\n            - Select your Electricity Distribution Company\n            - Enter your Electricity Consumer Number\n            - Enter Mobile Number\n            - Enter Email\n            - Please follow as per the direction from the portal.\n**Step-3** : Login with Consumer Number &amp;amp; Mobile Number.\n**Step-4** : Apply for the Rooftop Solar as per the form.\n**Step-5** : Fill out the online application form.\n**Step-6** : Wait for the feasibility approval from DISCOM. Once you get the feasibility approval install the plant by any of the registered vendors in your DISCOM.\n**Step-7** : Once installation is over, submit the plant details and apply for net meter.\n**Step-8** : After installation of net meter and inspection by DISCOM, they will generate commissioning certificate from portal.\n**Step-9** : Once you get the commissioning report. Submit the bank account details and a cancelled cheque through the portal. You will receive your subsidy in your bank account within 30 days. \n<br>\n\n"
        }
      ],
