          "process": [
            {
              "type": "align_justify",
              "children": [
                {
                  "type": "block_quote",
                  "children": [
                    {
                      "text": "Registration Process as a Building/ Construction Worker:",
                      "bold": true,
                      "italic": true,
                      "underline": true
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 1: ",
                      "bold": true
                    },
                    {
                      "text": "Visit the official "
                    },
                    {
                      "type": "link",
                      "link": "https://kbocwwb.karnataka.gov.in/login",
                      "children": [
                        {
                          "text": "Website "
                        }
                      ]
                    },
                    {
                      "text": "of Karnataka Building & Other Construction Workers Welfare Board (KBOCWWB) and click on “Register”."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 2: ",
                      "bold": true
                    },
                    {
                      "text": "Select “Register as New Construction Worker” then enter your mobile number as per the Aadhaar Registered and verify with the received OTP."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 3: ",
                      "bold": true
                    },
                    {
                      "text": "From the dashboard, click on “Registration”."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 4:",
                      "bold": true
                    },
                    {
                      "text": " Fill in all the mandatory details and upload the required documents. Click on “Final Submit” to complete the registration process."
                    }
                  ]
                },
                {
                  "type": "block_quote",
                  "children": [
                    {
                      "text": "Application Process of the Welfare Scheme:",
                      "bold": true,
                      "underline": true
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 1: ",
                      "bold": true
                    },
                    {
                      "text": "Visit the official "
                    },
                    {
                      "type": "link",
                      "link": "https://kbocwwb.karnataka.gov.in/login",
                      "children": [
                        {
                          "text": "Website "
                        }
                      ]
                    },
                    {
                      "text": "of Karnataka Building & Other Construction Workers Welfare Board (KBOCWWB) and click on “Login”."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 2: ",
                      "italic": true,
                      "bold": true
                    },
                    {
                      "text": "Enter your registered mobile number and the received OTP."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 3: ",
                      "bold": true
                    },
                    {
                      "text": "From the dashboard, click on “Schemes” (After the user Registration is approved, the user can access the schemes page)."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 4: ",
                      "bold": true
                    },
                    {
                      "text": "Select the concerned scheme. Fill in all the mandatory details and upload the required documents."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 5: ",
                      "bold": true
                    },
                    {
                      "text": " Review the details and check the declaration box. Now click on “Submit” to complete the application process."
                    }
                  ]
                },
                {
