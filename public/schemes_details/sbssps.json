                {
                  "text": "Submit the duly filled and signed application form along with the documents to the Talathi Office."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 4: ",
                  "bold": true
                },
                {
                  "text": "Acquire the receipt/acknowledgment of the successful submission of the application form."
                }
              ]
            }
