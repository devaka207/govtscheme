                    },
                    {
                      "type": "paragraph",
                      "children": [
                        {
                          "text": "Step 1: ",
                          "bold": true
                        },
                        {
                          "text": "The applicant may visit and apply online at the "
                        },
                        {
                          "type": "link",
                          "link": "https://ikhedut.gujarat.gov.in/",
                          "children": [
                            {
