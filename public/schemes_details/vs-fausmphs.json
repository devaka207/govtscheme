      "applicationProcess": [
        {
          "mode": "Online",
          "url": "https://suneethi.sjd.kerala.gov.in",
          "process": [
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Registration Process:",
                  "bold": true
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 01:",
                  "bold": true
                },
                {
                  "text": " To avail of the benefits of the scheme, the applicant needs to visit "
                },
                {
                  "type": "link",
                  "link": "https://suneethi.sjd.kerala.gov.in",
                  "children": [
                    {
                      "text": "SUNEETHI- Online Service Application Portal"
                    }
                  ]
                },
                {
                  "text": ""
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 02:",
                  "bold": true
                },
                {
                  "text": " On the home page, click on “One time Registration”"
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 03:",
                  "bold": true
                },
                {
                  "text": " Fill in the details like Name, Email ID & Mobile Number and click on ‘Register’."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 04:",
                  "bold": true
                },
                {
                  "text": " The applicant needs to enter the verification code received on the mobile number and click on ‘Verify’."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 05:",
                  "bold": true
                },
                {
                  "text": " Now, a form will open to create the new profile, fill in all the mandatory details and click on ‘Register’."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Login/Application Process:",
                  "bold": true
                },
                {
                  "text": " "
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 01:",
                  "bold": true
                },
                {
                  "text": " Once the registration process is completed, the applicant should visit "
                },
                {
                  "type": "link",
                  "link": "https://suneethi.sjd.kerala.gov.in",
                  "children": [
                    {
                      "text": "SUNEETHI- Online Service Application Portal"
                    }
                  ]
                },
                {
                  "text": " and click on “Citizen Login”."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 02:",
                  "bold": true
                },
                {
                  "text": " Enter the user name i.e. Mobile Number and Password and click on “Sign in”."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 03:",
                  "bold": true
                },
                {
                  "text": " Now, the applicant needs to update all their details i.e. Personal Information, Contact Details, Identity Cards & Bank Details by clicking on the 'Edit' button."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 04:",
                  "bold": true
                },
                {
                  "text": " Once the applicant updated their profile successfully, the schemes will appear on the left side of the screen."
