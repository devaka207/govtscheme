              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 05:",
                  "bold": true
                },
                {
                  "text": " Select the scheme and click on the “Apply Now” button."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
