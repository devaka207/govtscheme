        ],
        "schemeImageUrl": "",
        "detailedDescription_md": "The Indian Council of Social Science Research (ICSSR), under the Ministry of Education, Government of India, provides financial assistance for the publication of high-quality doctoral theses, research project/fellowship reports, and seminar/conference papers in the field of social sciences. The maximum grant offered is Rs. 2,00,000, and manuscripts are evaluated by subject experts. The final publication must follow ICSSR publishing standards and is to be completed within one year from the date of grant. ICSSR pays the publisher directly and mandates submission of copies, royalty terms, and quality assurance. The publication must acknowledge ICSSR support.\n<br>\n\n",
        "benefits_md": "1.\tGrant up to Rs. 2,00,000 for publishing the approved manuscript.\n2.\tDirect payment to the publisher upon submission of required documents.\n3.\tIncludes cost of printing, editorial work, and production.\n4.\tRoyalty to be paid to the author (minimum 10% on actual sales).\n5.\tICSSR may purchase additional copies with a 25% discount.\n<br>\n\n",
        "exclusions_md": "1.\tIncomplete applications or missing documentation.\n<br>\n\n",
        "briefDescription": "The Indian Council of Social Science Research (ICSSR), under the Ministry of Education, Government of India, provides financial assistance for the publication of high-quality doctoral theses, research project/fellowship reports, and seminar/conference papers in the field of social sciences.",
        "detailedDescription": [
          {
            "type": "paragraph",
            "children": [
              {
                "text": "The Indian Council of Social Science Research (ICSSR), under the Ministry of Education, Government of India, provides financial assistance for the publication of high-quality doctoral theses, research project/fellowship reports, and seminar/conference papers in the field of social sciences. The maximum grant offered is Rs. 2,00,000, and manuscripts are evaluated by subject experts. The final publication must follow ICSSR publishing standards and is to be completed within one year from the date of grant. ICSSR pays the publisher directly and mandates submission of copies, royalty terms, and quality assurance. The publication must acknowledge ICSSR support."
              }
            ]
          },
          {
            "type": "paragraph",
            "children": [
              {
                "text": ""
              }
            ]
          }
        ],
        "benefitTypes": {
          "id": 1,
          "value": "cash",
          "label": "Cash"
        },
        "benefits": [
          {
            "type": "paragraph",
            "children": [
              {
                "text": "1.\tGrant up to Rs. 2,00,000 for publishing the approved manuscript."
              }
            ]
          },
          {
            "type": "paragraph",
            "children": [
              {
                "text": "2.\tDirect payment to the publisher upon submission of required documents."
              }
            ]
          },
          {
            "type": "paragraph",
            "children": [
              {
                "text": "3.\tIncludes cost of printing, editorial work, and production."
              }
            ]
          },
          {
            "type": "paragraph",
            "children": [
              {
                "text": "4.\tRoyalty to be paid to the author (minimum 10% on actual sales)."
              }
            ]
          },
          {
            "type": "paragraph",
            "children": [
              {
                "text": "5.\tICSSR may purchase additional copies with a 25% discount."
              }
            ]
          },
          {
            "type": "paragraph",
            "children": [
              {
                "text": ""
              }
            ]
          }
        ],
