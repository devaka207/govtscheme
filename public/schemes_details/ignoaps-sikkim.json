        "schemeImageUrl": "",
        "briefDescription": "The scheme “Indira Gandhi National Old Age Pension Scheme (IGNOAPS)” was started by the Department of Women & Child Welfare, Govt. of Sikkim in 2014. Under this scheme, a pension is provided to elderly citizens above the age of 60 years belonging to the Below Poverty Line (BPL) category.",
        "detailedDescription": [
          {
            "type": "align_justify",
            "children": [
              {
                "type": "paragraph",
                "children": [
                  {
                    "text": "The scheme “Indira Gandhi National Old Age Pension Scheme (IGNOAPS)” was started by the Department of Women & Child Welfare, Govt. of Sikkim in 2014. Under this scheme, a pension is provided to elderly citizens above the age of 60 years belonging to the Below Poverty Line (BPL) category and the beneficiary will receive a monthly pension of ₹ 1500/-, ₹ 2000/- & ₹ 2500/- as per eligibility criteria."
                  }
                ]
              }
            ]
          }
        ],
        "benefitTypes": {
          "id": 1,
          "value": "cash",
          "label": "Cash"
        },
        "benefits": [
          {
            "type": "ol_list",
            "children": [
              {
                "type": "list_item",
                "children": [
                  {
                    "text": "A monthly pension of ₹ 1500/- to the old aged person between the age group of 60 years – 69 years."
                  }
                ]
              },
              {
                "type": "list_item",
                "children": [
                  {
                    "text": "A monthly pension of ₹ 2000/- to the old aged person between the age group of 70 years + and above."
                  }
                ]
              },
              {
                "type": "list_item",
                "children": [
                  {
                    "text": "A monthly pension of ₹ 2500/- to the old aged persons having attained the age of 80 years and above."
                  }
                ]
              },
              {
                "type": "list_item",
                "children": [
                  {
                    "text": "The beneficiary will get a pension as long as he/she is alive."
                  }
                ]
              }
            ]
          }
        ],
        "exclusions": [
          {
            "type": "align_justify",
            "children": [
              {
                "type": "paragraph",
                "children": [
                  {
                    "text": "Any person receiving a pension from the Central/State Government or Local/ Statutory Body or from any organization substantially financed by the Central/State Government or Local/ Statutory Body will not be eligible to apply for this scheme."
                  }
                ]
              }
            ]
          }
        ],
        "detailedDescription_md": "The scheme “Indira Gandhi National Old Age Pension Scheme (IGNOAPS)” was started by the Department of Women &amp;amp; Child Welfare, Govt. of Sikkim in 2014. Under this scheme, a pension is provided to elderly citizens above the age of 60 years belonging to the Below Poverty Line (BPL) category and the beneficiary will receive a monthly pension of ₹ 1500/-, ₹ 2000/- &amp;amp; ₹ 2500/- as per eligibility criteria.\n"
      },
      "applicationProcess": [
        {
          "mode": "Offline",
          "url": "2.\thttp://sikkimsocialwelfare.gov.in/wp-content/uploads/2015/12/Application-Form-for-all-pension-schemes.pdf",
          "process": [
            {
              "type": "align_justify",
              "children": [
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 01:",
                      "bold": true
                    },
                    {
                      "text": " The applicant has to approach their concerned Gram Panchayat /Municipality / Municipal Corporation office. Consult with the designated authority about the applying procedure and the local department office for this scheme. Collect the application form."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": ""
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 02:",
                      "bold": true
                    },
                    {
                      "text": " Fill in all the mandatory fields of the application form and attach all the (self-attested) mandatory documents and submit it to the designated receiving authority."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": ""
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Post-Application Processes:",
                      "bold": true
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": ""
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 01:",
                      "bold": true
                    },
                    {
                      "text": " On receipt of an application in the prescribed Form, the same shall be scrutinized by the Selection Committee. Thereafter, the approval shall be accorded by the Secretary."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": ""
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 02:",
                      "bold": true
                    },
                    {
                      "text": " A copy of the order for the grant and payment of pensions shall be endorsed to the District Collectors, Sub-Divisional Magistrates, Gram Vikash Adhikari and Panchayats where the applicant actually resides and the applicant himself/herself."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": ""
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 03:",
                      "bold": true
                    },
                    {
                      "text": " The pension shall be distributed through Direct Benefit Transfer System or any other system as may be decided by the Sanctioning / Competent Authority from time to time."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": ""
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 04:",
                      "bold": true
                    },
                    {
                      "text": " If required, the concerned officer of the Social Justice, Empowerment and Welfare Department shall make a tour of the village to verify the continued existence of the beneficiary and other relevant particulars."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": ""
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 05:",
                      "bold": true
                    },
                    {
                      "text": " Each beneficiary of the Pensions should submit \"Life Certificate\" in the prescribed format in the month of November every year failing which it will be presumed that the beneficiary is either died or migrated outside the State of Sikkim and the payment of pension shall be stopped forthwith without further notice."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": ""
                    }
                  ]
                }
              ]
