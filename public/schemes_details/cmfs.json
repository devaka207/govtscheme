      "applicationProcess": [
        {
          "mode": "Online",
          "process": [
            {
              "type": "align_justify",
              "children": [
                {
                  "type": "ul_list",
                  "children": [
                    {
                      "type": "list_item",
                      "children": [
                        {
                          "text": "To avail the benefits of the scheme, eligible beneficiaries must submit the application form either at the office of the Assistant Director of Fisheries / District Fisheries In-Charge at the district level or online through the "
                        },
                        {
                          "type": "link",
                          "link": "https://eservices.uk.gov.in/",
                          "children": [
                            {
                              "text": "Apunni Sarkar Portal"
                            }
                          ]
                        },
                        {
                          "text": "."
                        }
                      ]
                    },
                    {
                      "type": "list_item",
                      "children": [
                        {
                          "text": "The application form must be accompanied by the Aadhaar card, land Khasra-Khatauni, permanent residence certificate, caste certificate, bank account details, and mobile number."
                        }
                      ]
                    },
                    {
                      "type": "list_item",
                      "children": [
                        {
                          "text": "Beneficiaries under the scheme will be selected on a priority basis as per the guidelines of the scheme, following a first-come, first-served basis."
                        }
                      ]
                    },
                    {
                      "type": "list_item",
                      "children": [
                        {
                          "text": "After submitting the application, a survey is conducted by fisheries inspectors or field personnel, and a proposal is prepared in collaboration with the beneficiary. Once the proposal is finalized, it is approved by the relevant district officer. Field personnel then supervise the work and provide technical assistance to ensure its completion, after which the subsidy is directly credited to the beneficiary’s account via DBT."
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": ""
                }
              ]
            }
          ],
          "process_md": "\n  - To avail the benefits of the scheme, eligible beneficiaries must submit the application form either at the office of the Assistant Director of Fisheries / District Fisheries In-Charge at the district level or online through the [Apunni Sarkar Portal](https://eservices.uk.gov.in/).  - The application form must be accompanied by the Aadhaar card, land Khasra-Khatauni, permanent residence certificate, caste certificate, bank account details, and mobile number.\n  - Beneficiaries under the scheme will be selected on a priority basis as per the guidelines of the scheme, following a first-come, first-served basis.\n  - After submitting the application, a survey is conducted by fisheries inspectors or field personnel, and a proposal is prepared in collaboration with the beneficiary. Once the proposal is finalized, it is approved by the relevant district officer. Field personnel then supervise the work and provide technical assistance to ensure its completion, after which the subsidy is directly credited to the beneficiary’s account via DBT.\n\n<br>\n\n"
