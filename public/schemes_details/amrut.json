            ]
          },
          {
            "type": "heading_four",
            "children": [
              {
                "text": "Coverage"
              }
            ]
          },
          {
            "type": "paragraph",
            "children": [
              {
                "text": "Five hundred cities",
                "bold": true
              },
              {
                "text": " have been selected under AMRUT. The category of cities that have been selected under AMRUT is given below:"
