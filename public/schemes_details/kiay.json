      "eligibilityCriteria": {
        "eligibilityDescription_md": "\n   1. The applicant should be a farmer.\n   1. The applicant should belong to the reported Panchayats of the identified blocks in the specified districts.\n   1. The applicant must be registered on the DBT portal.\n   1. Applicant&amp;#39;s bank account must be linked with the Aadhaar number,\n\n&gt; Note: Farmers cultivating on others&amp;#39; land will be identified and verified as &amp;quot;actual cultivators&amp;quot; through joint certification by the Agriculture Coordinator and Farmer Advisor. This process ensures that only genuine cultivators receive subsidy benefits.\n\n",
        "eligibilityDescription": [
          {
            "type": "align_justify",
            "children": [
              {
                "type": "ol_list",
                "children": [
                  {
                    "type": "list_item",
                    "children": [
                      {
                        "text": "The applicant should be a farmer."
                      }
                    ]
                  },
                  {
                    "type": "list_item",
                    "children": [
                      {
                        "text": "The applicant should belong to the reported Panchayats of the identified blocks in the specified districts."
                      }
                    ]
                  },
                  {
                    "type": "list_item",
                    "children": [
                      {
                        "text": "The applicant must be registered on the DBT portal."
                      }
                    ]
                  },
                  {
                    "type": "list_item",
                    "children": [
                      {
                        "text": "Applicant's bank account must be linked with the Aadhaar number,"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "block_quote",
                "children": [
                  {
                    "text": "Note: Farmers cultivating on others' land will be identified and verified as \"actual cultivators\" through joint certification by the Agriculture Coordinator and Farmer Advisor. This process ensures that only genuine cultivators receive subsidy benefits."
                  }
                ]
              }
            ]
          }
        ]
