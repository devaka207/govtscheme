      "applicationProcess": [
        {
          "mode": "Offline",
          "url": "",
          "process": [
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 1: ",
                  "bold": true
                },
                {
                  "text": "Request a hard copy of the format of the application form for the scheme from the concerned authority at your school/college."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 2: ",
                  "bold": true
                },
                {
                  "text": "In the application form, fill in all the mandatory fields, paste the passport-sized photograph (signed across), and attach all the (self-attested) mandatory documents."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 3: ",
                  "bold": true
                },
                {
                  "text": "Submit the duly filled and signed application form along with the documents to the concerned authority at your school/college."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 4: ",
                  "bold": true
                },
                {
                  "text": "Acquire the receipt/acknowledgment of the successful submission of the application form from the concerned authority at your school/college."
                }
              ]
            }
          ]
        }
      ],
      "schemeDefinitions": [],
      "eligibilityCriteria": {
        "eligibilityDescription_md": "\n1. The applicant should be a citizen of India.\n1. The applicant should be a domicile / permanent resident of the state of Maharashtra.\n1. The applicant should be a student admitted/enrolled in a school recognized by the Govt. of Maharashtra.\n1. The applicant should be a Person with Disability (Visually Handicapped, Low Vision, Hearing Impaired, Orthopedically Handicapped, etc).\n1. The percentage of the disability should be 40% or above.\n1. The applicant should have passed class 10th.\n1. The applicant should not have failed in the last qualifying examination.\n1. The applicant should be pursuing a post-metric qualification, i.e. Higher Secondary School (Class 11th, Class 12th), or a Technical/Professional Degree in Medical, Engineering, etc.\n\n",
