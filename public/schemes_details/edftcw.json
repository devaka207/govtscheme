      "applicationProcess": [
        {
          "mode": "Online",
          "process": [
            {
              "type": "block_quote",
              "children": [
                {
                  "text": "Registration",
                  "bold": true,
                  "underline": true
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 1:",
                  "bold": true
                },
                {
                  "text": " Visit the DBoCWWB "
                },
                {
                  "type": "link",
                  "link": "https://dbocwwb.delhi.gov.in/cwapp/MyLoginPage",
                  "children": [
                    {
                      "text": "website "
                    }
                  ]
                },
                {
                  "text": "and click “Register Now”."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 2:",
                  "bold": true
                },
                {
                  "text": " Enter the following mandatory details: Aadhaar Card Number, Name as on Aadhar Card, Mobile Number, Date of Birth (as on Aadhar Card), Gender, etc. Create a password and confirm it. Click “Register”. You will be redirected to the registration page."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 3:",
                  "bold": true
                },
                {
                  "text": " On the registration page, fill in the mandatory details (Father Name, Mother Name, Photograph, Applicant’s Video, etc) and upload the mandatory documents in the specified filetype and filesize. Click “Save & Next”."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 4:",
                  "bold": true
                },
                {
                  "text": " On the next page, enter the mandatory details regarding your work/workplace (Previous/Current Employer Details, Proof of 90 Days Employment, etc) and upload the mandatory documents in the specified filetype and filesize. Click “Save & Next”."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 5:",
                  "bold": true
                },
                {
                  "text": " Click on “Add Family Members” to avail the benefits of various schemes."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 6:",
                  "bold": true
                },
                {
                  "text": " In the next window, add your Bank Account details."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 7: ",
                  "bold": true
                },
                {
                  "text": "In the next window, upload your Aadhaar Card, Address Proof, Birth Proof, Employment Proof, Bank Account details etc."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 8:",
                  "bold": true
                },
                {
                  "text": " In the next window, the \"Affidavit of the Applicant\" will be displayed. Verify all the details, and click on the checkbox."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 9:",
                  "bold": true
                },
                {
                  "text": " Proceed for the online registration fee of ₹25/- through a Debit Card/ Internet Banking/ UPI."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 10:",
                  "bold": true
                },
                {
                  "text": " Enter the OTP received on your registered mobile number to apply. Note down the Application Number for future reference. Download the acknowledgement receipt."
                }
              ]
            },
            {
              "type": "block_quote",
              "children": [
                {
                  "text": "Track Your Application",
                  "bold": true,
                  "underline": true
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Visit the "
                },
                {
                  "type": "link",
                  "link": "https://dbocwwb.delhi.gov.in/",
                  "children": [
                    {
                      "text": "homepage "
                    }
                  ]
                },
                {
                  "text": "of the website regularly and click on \"Track Your Application\" to check the status of your application."
                }
              ]
            },
