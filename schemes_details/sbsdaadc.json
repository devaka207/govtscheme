            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 2:",
                  "bold": true
                },
                {
                  "text": " On the top menu bar, click on \"Apply Now\"."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 3:",
                  "bold": true
                },
                {
                  "text": " Click on the loan scheme name. "
