              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 4: ",
                  "bold": true
                },
                {
                  "text": "Select the loan category and fill in the loan amount."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 5: ",
                  "bold": true
                },
                {
                  "text": "Fill out the Application Form, enter the following details:"
