              ]
            },
            {
              "type": "ul_list",
              "children": [
                {
                  "type": "list_item",
                  "children": [
                    {
                      "text": "Personal Information: Name, gender, date of birth, caste, etc."
                    }
                  ]
                },
                {
                  "type": "list_item",
                  "children": [
                    {
                      "text": "Address Information: Permanent and correspondence address"
                    }
                  ]
                },
                {
                  "type": "list_item",
                  "children": [
                    {
                      "text": "Income Details: Monthly family income and source"
                    }
                  ]
                },
                {
                  "type": "list_item",
                  "children": [
                    {
                      "text": "Loan Requirement: Amount needed, proposed use (e.g., business, self-employment)"
                    }
                  ]
                },
                {
                  "type": "list_item",
                  "children": [
                    {
                      "text": "Bank Account Details: For loan disbursement"
                    }
                  ]
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 6: ",
                  "bold": true
                },
                {
                  "text": "Upload scanned copies of the Caste certificate, Income certificate, Aadhaar card, Passport-size photo, Bank passbook (first page), and Residence proof."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 7:",
                  "bold": true
                },
                {
                  "text": " Double-check all details. Click on “Preview” to verify. If all details are correct, click “Submit”."
