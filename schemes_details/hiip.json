        "schemeImageUrl": "",
        "briefDescription": "The \"Homes for Intellectually Impaired Persons\" is a scheme by the Department of Social Justice & Special Assistance, Govt. of Maharashtra. In this scheme, Mentally Deficient Children who are in need of care and protection are admitted into shelter homes through the Child Welfare Committees.",
        "detailedDescription": [
          {
            "type": "paragraph",
            "children": [
              {
                "text": "The \"Homes for Intellectually Impaired Persons\" is a scheme by the Department of Social Justice & Special Assistance, Govt. of Maharashtra. In this scheme, Mentally Deficient Children who are in need of care and protection are admitted into shelter homes through the Child Welfare Committee of the district formed under the Juvenile Justice (Care & Protection of Children) Act 2000 and Amendment Act 2006. The numbers of MDC homes are 19 out of which 14 are granted and 5 are non-granted."
              }
            ]
          }
        ],
        "benefitTypes": {
          "id": 2,
          "value": "in-kind",
          "label": "In Kind"
        },
        "benefits": [
          {
            "type": "ol_list",
            "children": [
              {
                "type": "list_item",
                "children": [
                  {
                    "text": "The Mentally Deficient Children who are in need of care and protection are admitted into shelter homes."
                  }
                ]
              },
              {
                "type": "list_item",
                "children": [
                  {
                    "text": "There are free facilities of food, shelter, and care & protection are provided in these homes."
                  }
                ]
              }
            ]
          }
        ],
        "detailedDescription_md": "The &quot;Homes for Intellectually Impaired Persons&quot; is a scheme by the Department of Social Justice &amp; Special Assistance, Govt. of Maharashtra. In this scheme, Mentally Deficient Children who are in need of care and protection are admitted into shelter homes through the Child Welfare Committee of the district formed under the Juvenile Justice (Care &amp; Protection of Children) Act 2000 and Amendment Act 2006. The numbers of MDC homes are 19 out of which 14 are granted and 5 are non-granted.\n"
      },
