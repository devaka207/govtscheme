      "applicationProcess": [
        {
          "mode": "Online",
          "process": [
            {
              "type": "align_justify",
              "children": [
                {
                  "type": "block_quote",
                  "children": [
                    {
                      "text": "Application Process:",
                      "bold": true
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "bold": true,
                      "text": "Step 1:"
                    },
                    {
                      "text": " The applicant may visit and apply online at I-Khedut Portal: "
                    },
                    {
                      "type": "link",
                      "link": "https://ikhedut.gujarat.gov.in/",
                      "children": [
                        {
                          "text": "https://ikhedut.gujarat.gov.in/"
                        }
                      ]
                    },
                    {
                      "text": ""
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 2:",
                      "bold": true
                    },
                    {
                      "text": " On the home page, click on ‘Schemes’ and then click on ‘Agricultural Schemes’."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 3:",
                      "bold": true
                    },
                    {
                      "text": " Now select the scheme, click on the ‘Apply’ button and an application page will open."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 4:",
                      "bold": true
                    },
                    {
                      "text": " Click on \"Apply New\" button and submit a new application."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 5:",
                      "bold": true
                    },
                    {
                      "text": " Click on the \"Update Application\" button to add corrections to the application."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 6: ",
                      "bold": true
                    },
                    {
                      "text": "Once the application is done, confirm it."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 7:",
                      "bold": true
                    },
                    {
                      "text": " Take a print out of the confirmed application."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 8:",
                      "bold": true
                    },
                    {
                      "text": " Applicant can also check their Application Status/View/Print/Upload Application details from the below link: "
                    },
                    {
                      "type": "link",
                      "link": "https://ikhedut.gujarat.gov.in/public/frm_Applicant_Corner.aspx",
                      "children": [
                        {
                          "text": "https://ikhedut.gujarat.gov.in/public/frm_Applicant_Corner.aspx"
                        }
                      ]
                    },
                    {
                      "text": " "
                    }
                  ]
                },
                {
                  "type": "block_quote",
                  "children": [
                    {
                      "text": "Post- Application Process:",
                      "bold": true
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "bold": true,
                      "text": "Step 1:"
                    },
                    {
                      "text": " After applying, they must print the application, sign or provide a thumb impression, and keep a copy."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 2:",
                      "bold": true
                    },
                    {
                      "text": " Approval for construction is granted based on the application."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 3:",
                      "bold": true
                    },
                    {
                      "text": " The farmer must construct the storage structure as per government rules within the specified timeframe."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 4:",
                      "bold": true
                    },
                    {
                      "text": " After construction, the signed application and assistance case paper must be submitted to the concerned office for financial support."
                    }
                  ]
                },
                {
                  "type": "block_quote",
                  "children": [
