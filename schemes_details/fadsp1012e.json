      "applicationProcess": [
        {
          "mode": "Offline",
          "process": [
            {
              "type": "align_justify",
              "children": [
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 01:",
                      "bold": true
                    },
                    {
                      "text": " To avail of the benefits of the scheme, the applicant needs to visit the nearest Anganwadi Centre or District Social Justice Office and collect the application form. The "
                    },
                    {
                      "type": "link",
                      "link": "http://sjd.kerala.gov.in/DOCUMENTS/Downloadables/Application%20Forms/24910.pdf",
                      "children": [
                        {
                          "text": "application form"
                        }
                      ]
                    },
                    {
                      "text": " can also be downloaded from the official website of the Social Justice Department, Government of Kerala."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 02:",
                      "bold": true
                    },
                    {
                      "text": " The applicant needs to fill out the application form completely"
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 03:",
                      "bold": true
                    },
                    {
                      "text": " The application may be submitted to the District Social Justice Officers (DSJOs) or the concerned Anganwadi Centre."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Note 01:",
                      "bold": true
                    },
                    {
                      "text": " The DSJOs have to make sure that the applicants have completed their courses and that the certificates issued by State Literacy Mission have been correctly distributed to the respective applicants in that academic year."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Note 02:",
                      "bold": true
                    },
                    {
                      "text": " The list of beneficiaries will be prepared based on the applications collected through the Anganwadi workers and inquiries by the concerned Child Development Project Officers (CDPOs)."
                    }
                  ]
                }
              ]
            }
          ],
          "process_md": "**Step 01:** To avail of the benefits of the scheme, the applicant needs to visit the nearest Anganwadi Centre or District Social Justice Office and collect the application form. The [application form](http://sjd.kerala.gov.in/DOCUMENTS/Downloadables/Application%20Forms/24910.pdf) can also be downloaded from the official website of the Social Justice Department, Government of Kerala.\n**Step 02:** The applicant needs to fill out the application form completely\n**Step 03:** The application may be submitted to the District Social Justice Officers (DSJOs) or the concerned Anganwadi Centre.\n**Note 01:** The DSJOs have to make sure that the applicants have completed their courses and that the certificates issued by State Literacy Mission have been correctly distributed to the respective applicants in that academic year.\n**Note 02:** The list of beneficiaries will be prepared based on the applications collected through the Anganwadi workers and inquiries by the concerned Child Development Project Officers (CDPOs).\n"
        }
