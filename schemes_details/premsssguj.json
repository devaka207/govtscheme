                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "align_justify",
                  "children": [
                    {
                      "type": "paragraph",
                      "children": [
                        {
                          "text": "Step 01:",
                          "bold": true
                        },
                        {
                          "text": " The applicant may visit the "
