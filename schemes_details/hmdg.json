        "schemeImageUrl": "",
        "briefDescription": "A health scheme by Ministry of Health & Family Welfare for financially poor patients to defray a part of the expenditure on Hospitalization/treatment in Government Hospitals,for life threatening diseases covered under Rashtriya Arogya Nidhi (RAN), in cases where free medical facilities aren't there.",
        "detailedDescription": [
          {
            "type": "paragraph",
            "children": [
              {
                "text": "A health scheme by Ministry of Health & Family Welfare for financially poor patients to defray a part of the expenditure on Hospitalization/treatment in Government Hospitals,for life threatening diseases covered under Rashtriya Arogya Nidhi (RAN), in cases where free medical facilities are not available. Only those having annual family income up to Rs.1.25,000/- and below are eligible for financial assistance from Health Minister’s Discretionary Grant (HMDG). Under this scheme, Financial assistance is provided towards treatment in Government hospitals including super specialty Government hospitals / institutes."
              }
            ]
          }
        ],
        "benefitTypes": {
          "value": "Cash",
          "label": "Cash"
        },
        "benefits": [
          {
            "type": "paragraph",
            "children": [
              {
                "text": "Financial assistance towards treatment in Government hospitals including super specialty Government hospitals / institutes.",
                "bold": true
              }
            ]
          },
          {
            "type": "ol_list",
            "children": [
              {
                "type": "list_item",
                "children": [
                  {
                    "text": "Financial Assistance of ₹50,000/- if the estimated cost of treatment is up to ₹1,00,000/- ."
                  }
                ]
              },
              {
                "type": "list_item",
                "children": [
                  {
                    "text": "Financial Assistance of ₹75,000/- if the estimated cost of treatment is above ₹1,00,000/- & up to ₹1,50,000/-."
                  }
                ]
              },
              {
                "type": "list_item",
                "children": [
                  {
                    "text": "Financial Assistance of ₹1,00,000/- if the estimated cost of treatment is above ₹1,50,000/-."
                  }
                ]
              }
            ]
          },
          {
            "type": "paragraph",
            "children": [
              {
                "text": ""
              }
            ]
          }
        ],
        "exclusions": [
