      "applicationProcess": [
        {
          "mode": "Offline",
          "process": [
            {
              "type": "ul_list",
              "children": [
                {
                  "type": "list_item",
                  "children": [
                    {
                      "text": "Victim or dependent files an application with District Legal Services Authority (DLSA)."
                    }
                  ]
                },
                {
                  "type": "list_item",
                  "children": [
                    {
                      "text": "DLSA verifies claims, collects necessary documents, and may call for additional evidence."
                    }
                  ]
                },
                {
                  "type": "list_item",
                  "children": [
                    {
                      "text": "Compensation is determined based on severity of loss, medical expenses, and rehabilitation needs within 60 days."
                    }
                  ]
                },
                {
                  "type": "list_item",
                  "children": [
                    {
                      "text": "Interim relief or medical assistance may be provided immediately."
                    }
                  ]
                },
                {
                  "type": "list_item",
                  "children": [
                    {
                      "text": "Approved compensation is disbursed through Aadhaar-linked bank accounts."
                    }
                  ]
                },
                {
                  "type": "list_item",
                  "children": [
                    {
                      "text": "Appeals can be filed with the State Legal Services Authority within 90 days; second appeal to Government Home Department within 30 days."
                    }
                  ]
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": ""
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": ""
                }
              ]
            }
          ],
          "process_md": "\n- Victim or dependent files an application with District Legal Services Authority (DLSA).\n- DLSA verifies claims, collects necessary documents, and may call for additional evidence.\n- Compensation is determined based on severity of loss, medical expenses, and rehabilitation needs within 60 days.\n- Interim relief or medical assistance may be provided immediately.\n- Approved compensation is disbursed through Aadhaar-linked bank accounts.\n- Appeals can be filed with the State Legal Services Authority within 90 days; second appeal to Government Home Department within 30 days.\n\n<br>\n\n<br>\n\n"
        }
      ],
      "schemeDefinitions": [],
      "eligibilityCriteria": {
        "eligibilityDescription_md": "\n1. The applicant should be a victim of crime or a dependent of a victim who has suffered injury or loss due to criminal acts.\n1. The crime should have occurred within Madhya Pradesh. Victims outside the state but residing in Madhya Pradesh are eligible for interim relief.\n1. The applicant must report the crime without unreasonable delay.\n1. The applicant must cooperate with authorities in investigation and rehabilitation process.\n1. The annual income of the victim from all sources must not exceed ₹5,00,000. If it exceeds, compensation is limited to 50% of the prescribed amount.\n\n<br>\n\n<br>\n\n",
        "eligibilityDescription": [
