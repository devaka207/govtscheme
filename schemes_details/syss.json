      "applicationProcess": [
        {
          "mode": "Offline",
          "url": "https://industries.sikkim.gov.in/wp-content/uploads/2021/03/Youth-Skilled-Start-Up-Scheme-converted.pdf",
          "process": [
            {
              "type": "align_justify",
              "children": [
                {
                  "type": "ol_list",
                  "children": [
                    {
                      "type": "list_item",
                      "children": [
                        {
                          "text": "Submit the prescribed application form ("
                        },
                        {
                          "type": "link",
                          "link": "https://industries.sikkim.gov.in/schemedoc/dcKnMRZtT1BAFaojSbxG110KbPQdHieY25oRlwJr.pdf",
                          "children": [
                            {
                              "text": "Annexure-I"
                            }
                          ]
                        },
                        {
                          "text": ") along with the Detailed Project Report (DPR) and required documents to:"
                        }
                      ]
                    },
                    {
                      "type": "list_item",
                      "children": [
                        {
                          "text": "General Manager, District Industries Centre (DIC) at Gangtok or Jorethang."
                        }
                      ]
                    },
                    {
                      "type": "list_item",
                      "children": [
                        {
                          "text": "Application is reviewed by a Selection Committee comprising departmental and bank representatives."
                        }
                      ]
                    },
                    {
                      "type": "list_item",
                      "children": [
                        {
                          "text": "Post-approval, the project is forwarded to banks for loan sanctioning."
                        }
                      ]
                    },
                    {
                      "type": "list_item",
                      "children": [
                        {
                          "text": "Training completion is mandatory before disbursement."
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": ""
                    }
                  ]
                },
                {
                  "type": "block_quote",
                  "children": [
                    {
                      "text": "Repayment of Loan:",
                      "bold": true,
                      "underline": true
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Repayment of the loan amount along with interest obtained from the bank shall be the sole responsibility of the applicant as per the terms and conditions of the bank. If the beneficiary wants to close the loan account before the completion of the loan period, he can do so with the approval of the Commerce & Industries Department. If the beneficiary wants to close after one year, they are free to do for agriculture & allied activities, and for other projects, the lock-in is 3 years."
                    }
                  ]
