      "applicationProcess": [
        {
          "mode": "Online",
          "process": [
            {
              "type": "block_quote",
              "children": [
                {
                  "text": "Registration:",
                  "bold": true,
                  "underline": true
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "bold": true,
                  "text": "Step 1: "
                },
                {
                  "text": "Visit the official ESDM Skill Development portal: "
                },
                {
                  "type": "link",
                  "link": "https://esdm-skill.deity.gov.in",
                  "children": [
                    {
                      "text": "https://esdm-skill.deity.gov.in."
                    }
                  ]
                },
                {
                  "text": ""
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 2: ",
                  "bold": true
                },
                {
                  "text": "Identify the nearest affiliated Training Partner (TP) through the portal or authorised sources."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 3: ",
                  "bold": true
                },
                {
                  "text": "Approach the Training Partner for counselling and selection of the appropriate NSQF course."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 4: ",
                  "bold": true
                },
                {
                  "text": "Submit required documents and eligibility details to the Training Partner."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 5: ",
                  "bold": true
                },
                {
                  "text": "Provide Aadhaar Number or Aadhaar Enrolment ID and complete Aadhaar authentication / e-KYC (with consent)."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 6: ",
                  "bold": true
                },
                {
                  "text": "Fill the application/enrolment form at the Training Partner centre or through the portal."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 7: ",
                  "bold": true
                },
                {
                  "text": "Pay the Registration-cum-Certification Fee (RCCF) to the Training Partner."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 8: ",
                  "bold": true
                },
                {
                  "text": "Submit required undertakings:"
                }
              ]
            },
            {
              "type": "ul_list",
              "children": [
                {
                  "type": "list_item",
                  "children": [
                    {
                      "text": "Undertaking for the non-availability of a similar Government scheme"
                    }
                  ]
                },
                {
                  "type": "list_item",
                  "children": [
                    {
                      "text": "Undertaking for willingness for employment/self-employment"
                    }
                  ]
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 9:",
                  "bold": true
                },
                {
                  "text": "The Training Partner verifies eligibility and completes enrolment of the applicant."
                }
              ]
            },
            {
              "type": "block_quote",
              "children": [
                {
                  "text": "After Registration:",
                  "bold": true,
                  "underline": true
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "bold": true,
                  "text": "Step 1: "
                },
                {
                  "text": "The applicant undergoes training for the prescribed duration as per the selected NSQF course."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 2: ",
                  "bold": true
                },
                {
                  "text": "The applicant maintains the required attendance (minimum 70%) during training."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 3: ",
                  "bold": true
                },
                {
                  "text": "The applicant appears for assessment conducted by the respective Key Implementing Agency (KIA)."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 4: ",
                  "bold": true
                },
                {
                  "text": "Upon successful assessment, the applicant receives certification."
                }
              ]
            },
            {
              "type": "paragraph",
