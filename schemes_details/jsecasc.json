      "schemeDefinitions": [],
      "eligibilityCriteria": {
        "eligibilityDescription_md": "\n1. The applicant should be a coach who trains medal-winning athletes/teams participating in competitions recognized by the International or Indian Olympic Association.\n1. The applicant must have coached athletes/teams representing Jharkhand or India for at least four years.\n1. The medal-winning athletes must have competed in recognized competitions for the coach to qualify.\n\n<br>\n\n",
        "eligibilityDescription": [
          {
            "type": "ol_list",
            "children": [
              {
                "type": "list_item",
                "children": [
                  {
                    "text": "The applicant should be a coach who trains medal-winning athletes/teams participating in competitions recognized by the International or Indian Olympic Association."
                  }
                ]
              },
              {
                "type": "list_item",
                "children": [
                  {
                    "text": "The applicant must have coached athletes/teams representing Jharkhand or India for at least four years."
                  }
                ]
              },
              {
                "type": "list_item",
                "children": [
                  {
                    "text": "The medal-winning athletes must have competed in recognized competitions for the coach to qualify."
                  }
