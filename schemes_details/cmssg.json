      "applicationProcess": [
        {
          "mode": "Online",
          "process": [
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 1:",
                  "bold": true
                },
                {
                  "text": " Students must register on "
                },
                {
                  "type": "link",
                  "link": "https://scholarships.gujarat.gov.in/",
                  "children": [
                    {
                      "text": ""
                    }
                  ]
                },
                {
                  "text": "the "
                },
                {
                  "type": "link",
                  "link": "https://scholarships.gujarat.gov.in/",
                  "children": [
                    {
                      "text": "Official Website"
                    }
                  ]
                },
                {
                  "text": " using their Standard 10th or Standard 12th seat number. Do not use any spaces or special characters when entering the seat number."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 2:",
                  "bold": true
                },
                {
                  "text": " Students applying for a Diploma to Degree course should use their Diploma enrollment number for registration."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 3:",
                  "bold": true
                },
                {
                  "text": " The student's name must be entered exactly as it appears on their Standard 10 or 12 original marksheet."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 4:",
                  "bold": true
                },
                {
                  "text": " Enter the passing year according to the marksheet (e.g., 2024)."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Provide a personal mobile number that will remain active throughout the entire course of study, as important updates will be sent via SMS to this number."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 5:",
                  "bold": true
                },
                {
                  "text": " Enter and verify your 12-digit Aadhaar card number."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 6:",
                  "bold": true
                },
                {
                  "text": " Fill in the correct ration card details, including the ration card number and the student's member ID number."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 7:",
                  "bold": true
                },
                {
                  "text": " Provide accurate bank account details and an active email ID."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 8:",
                  "bold": true
                },
                {
                  "text": " Enter the percentage from the marksheet; if percentages are not available, calculate them according to the rules of the university or board."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 9:",
                  "bold": true
                },
                {
                  "text": " When selecting a stream, students from Arts and Commerce streams should choose \"General Stream,\" while Science students should select \"Science Stream\"."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": ""
                }
              ]
            }
          ],
          "process_md": "**Step 1:** Students must register on the [Official Website](https://scholarships.gujarat.gov.in/) using their Standard 10th or Standard 12th seat number. Do not use any spaces or special characters when entering the seat number.\n**Step 2:** Students applying for a Diploma to Degree course should use their Diploma enrollment number for registration.\n**Step 3:** The student&#39;s name must be entered exactly as it appears on their Standard 10 or 12 original marksheet.\n**Step 4:** Enter the passing year according to the marksheet (e.g., 2024).\nProvide a personal mobile number that will remain active throughout the entire course of study, as important updates will be sent via SMS to this number.\n**Step 5:** Enter and verify your 12-digit Aadhaar card number.\n**Step 6:** Fill in the correct ration card details, including the ration card number and the student&#39;s member ID number.\n**Step 7:** Provide accurate bank account details and an active email ID.\n**Step 8:** Enter the percentage from the marksheet; if percentages are not available, calculate them according to the rules of the university or board.\n**Step 9:** When selecting a stream, students from Arts and Commerce streams should choose &quot;General Stream,&quot; while Science students should select &quot;Science Stream&quot;.\n<br>\n\n"
        }
