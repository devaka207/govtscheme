            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 2: ",
                  "bold": true
                },
                {
                  "text": "Fill in all the mandatory fields, paste the passport-sized photograph (signed across), and attach all the (self-attested) mandatory documents."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 3: ",
                  "bold": true
                },
                {
                  "text": "Submit the duly filled and signed application form along with the documents to the District Office."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 4: ",
                  "bold": true
                },
                {
                  "text": "Acquire the receipt/acknowledgment of the successful submission of the application form from the District Office."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": ""
                }
              ]
            },
            {
              "type": "block_quote",
              "children": [
                {
                  "text": "Post-Application Processes:",
                  "bold": true
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 1: ",
                  "bold": true
                },
                {
                  "text": "The District Manager sponsors the application to the concerned bank branch for joint verification."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 2: ",
                  "bold": true
                },
                {
                  "text": "The cases are sanctioned & subsidy is claimed by the banks."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 3: ",
                  "bold": true
                },
                {
                  "text": "Then these cases are referred to the District level committee chaired by the ADC. "
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 4: ",
                  "bold": true
                },
                {
                  "text": "The loan is disbursed to the beneficiaries by the banks along with the subsidy."
                }
              ]
            }
