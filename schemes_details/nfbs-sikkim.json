        "schemeImageUrl": "",
        "briefDescription": "The scheme “National Family Benefit Scheme (NFBS)” was launched in 2016 by the Department of Women & Child Welfare, Govt. of Sikkim. Under this scheme, a lump sum amount of ₹ 30,000/- as financial assistance is provided to the bereaved household in the event of the death of the \"Primary breadwinner\"",
        "detailedDescription": [
          {
            "type": "align_justify",
            "children": [
              {
                "type": "paragraph",
                "children": [
                  {
                    "text": "The scheme “National Family Benefit Scheme (NFBS)” was launched in 2016 by the Department of Women & Child Welfare, Govt. of Sikkim. Under this scheme, a lump sum amount of ₹ 30,000/- as financial assistance is provided to the bereaved household in the event of the death of the \"Primary breadwinner\" belonging to the Below Poverty Line (BPL) Category. The one-time grant amount consists of Central and State Government Share. (i.e. ₹ 20,000/- as Central Share and ₹ 10,000/- as State Share)"
                  }
                ]
              }
            ]
          }
        ],
        "benefitTypes": {
          "id": 1,
          "value": "cash",
          "label": "Cash"
        },
        "benefits": [
          {
            "type": "ol_list",
            "children": [
              {
                "type": "list_item",
                "children": [
                  {
                    "text": "The beneficiary will receive a one-time grant of ₹ 30,000/- as financial assistance."
                  }
                ]
              },
              {
                "type": "list_item",
                "children": [
                  {
                    "text": "The assistance would be given to every case of death of a breadwinner in a family of the Below Poverty Line (BPL) category."
                  }
                ]
              }
            ]
          }
        ],
        "exclusions": [
          {
            "type": "paragraph",
            "children": [
              {
                "text": ""
              }
            ]
          }
        ],
        "detailedDescription_md": "The scheme “National Family Benefit Scheme (NFBS)” was launched in 2016 by the Department of Women &amp;amp; Child Welfare, Govt. of Sikkim. Under this scheme, a lump sum amount of ₹ 30,000/- as financial assistance is provided to the bereaved household in the event of the death of the &amp;quot;Primary breadwinner&amp;quot; belonging to the Below Poverty Line (BPL) Category. The one-time grant amount consists of Central and State Government Share. (i.e. ₹ 20,000/- as Central Share and ₹ 10,000/- as State Share)\n"
      },
