      "applicationProcess": [
        {
          "mode": "Online",
          "process": [
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Registration of New Institute:",
                  "bold": true
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 01: Visit "
                },
                {
                  "type": "link",
                  "link": "http://portal.aicte-india.org/partnerportal_enu/start.swe",
                  "children": [
                    {
                      "text": "http://portal.aicte-india.org/partnerportal_enu/start.swe"
                    }
                  ]
                },
                {
                  "text": " and click on "
                },
                {
                  "text": "'New Institute' ",
                  "bold": true
                },
                {
                  "text": "button."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 02: Users will be redirected to another website. Hover the cursor on Login and select "
                },
                {
                  "text": "‘Investor Login’.",
                  "bold": true
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 03: New users need to click on "
                },
                {
                  "text": "‘Sign Up Now’",
                  "bold": true
                },
                {
                  "text": " to register."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 04: Enter the details and click on "
                },
                {
                  "text": "‘Verify’",
                  "bold": true
                },
                {
                  "text": " to receive OTP on your Email Id and Mobile Number."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 05: After successful verification Click on "
                },
                {
                  "text": "‘Sign Up Now’",
                  "bold": true
                },
                {
                  "text": " to register."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": ""
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Post-Registration Process:",
                  "bold": true
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 01: Visit "
                },
                {
                  "type": "link",
                  "link": "http://portal.aicte-india.org/partnerportal_enu/start.swe",
                  "children": [
                    {
                      "text": "http://portal.aicte-india.org/partnerportal_enu/start.swe"
                    }
                  ]
                },
                {
                  "text": " and log in with the credentials provided by AICTE."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 02: Navigate to AQIS Application Screen by clicking on "
                },
                {
                  "text": "‘AQIS Application’ ",
                  "bold": true
                },
                {
                  "text": "screen tab."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 03: Institute details will auto populate in the AQIS Application."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 04: Fill demographic and Bank details ."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 05: Only after confirming the Bank Details, the "
                },
                {
                  "text": "“New”",
                  "bold": true
                },
                {
                  "text": " button will be enabled for adding the AQIS Application. Click on "
                },
                {
                  "text": "“New”",
                  "bold": true
                },
                {
                  "text": " button to create AQIS Application."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 06: A unique AQIS Application ID will get created. Select the "
                },
                {
                  "text": "\"TRAINING PROGRAMS FOR PHYSICAL EDUCATION TRAINERS/SPORT-GAMES TEACHERS/DIRECTOR OF SPORTS\"",
                  "bold": true
                },
                {
                  "text": " as Scheme from the drop down List."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 07: Now details to be filled for the as followed: Program Details, Personalities Expected, Participating Industries ,Similar Events, Budget Estimate -Others, Academic Credentials of Coordinator/ PI/ Applicant, Justification, Credential of Institute / Department."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 07: Once the user has filled all the data in the above mentioned tab, user should click on ‘Validate Application’ button on the "
                },
                {
                  "text": "‘AQIS Application’",
                  "bold": true
                },
                {
                  "text": " tab."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 08: User will get a pop up message to attach a Mandate Form  after downloading the sample form."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 09: Now fill the amount in the "
                },
                {
                  "text": "‘Total Funds Requested’",
                  "bold": true
                },
                {
                  "text": " under label "
                },
                {
                  "text": "‘Budget Estimates Others’.",
                  "bold": true
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 10: After Validation is completed successfully, read the declaration, check it and click on Save."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 10: Click on '"
                },
                {
                  "text": "Submit'",
                  "bold": true
                },
                {
                  "text": " button to submit the application."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": ""
                }
              ]
            },
