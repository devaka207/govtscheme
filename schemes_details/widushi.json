      "applicationProcess": [
        {
          "mode": "Online",
          "process": [
            {
              "type": "align_justify",
              "children": [
                {
                  "type": "block_quote",
                  "children": [
                    {
                      "text": "Registration Process:",
                      "bold": true
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 01:",
                      "bold": true
                    },
                    {
                      "text": " The proposal submission is open throughout the year."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 02:",
                      "bold": true
                    },
                    {
                      "text": " The proposal format is available at "
                    },
                    {
                      "type": "link",
                      "link": "https://dst.gov.in/",
                      "children": [
                        {
                          "text": "https://dst.gov.in"
                        }
                      ]
                    },
                    {
                      "text": "/ and "
                    },
                    {
                      "type": "link",
                      "link": "https://onlinedst.gov.in/",
                      "children": [
                        {
                          "text": "https://onlinedst.gov.in/"
                        }
                      ]
                    },
                    {
                      "text": " under WISE-KIRAN Division."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 03:",
                      "bold": true
                    },
                    {
                      "text": " Log on to "
                    },
                    {
                      "type": "link",
                      "link": "https://onlinedst.gov.in/",
                      "children": [
                        {
                          "text": "https://onlinedst.gov.in/"
                        }
                      ]
                    },
                    {
                      "text": " to access the home page of the “DST e-PMS Portal”."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 04:",
                      "bold": true
                    },
                    {
                      "text": " Click on “New PI Registration” and fill in the requisite details for New user registration. In the ‘Personal Information’ section, fill- department, Institute, and Institute Address as per the Host Institute identified for the WIDUSHI programme."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 05:",
                      "bold": true
                    },
                    {
                      "text": " After logging in, click on the “Submit proposal” option and then “Initiate New Proposal”. Search the programme by Division Name or Call By Programme/Scheme."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 06:",
                      "bold": true
                    },
                    {
                      "text": " Select the Programme/Scheme name (WIDUSHI) and then click on “Start Submission”. Select the category and fill in all the information as required in the form."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 07:",
                      "bold": true
                    },
                    {
                      "text": " After filling in all the particulars, preview your details before the final submission of the application form by clicking on the “Preview” button. The preview page will display all the facts/ particulars that you have mentioned. If there is something that you wish to update, go back and correct the information, or else proceed with the filled details by clicking on the “Submit” button to finally push data into the server."
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "Step 08:",
                      "bold": true
                    },
                    {
                      "text": " Candidates are advised to carefully fill and verify the details filled in the online application themselves as no change will be possible/ entertained after clicking the FINAL SUBMIT BUTTON."
                    }
                  ]
                },
                {
                  "type": "block_quote",
                  "children": [
                    {
                      "text": "Selection Process:",
                      "bold": true
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "The project proposals received will be screened and the Principal Investigator (PI) of ‘screened-in’ proposals will be called for presentation before Programme Advisory Committee for final recommendation. The final decision of DST will be communicated to the applicants only after obtaining due administrative and financial approvals."
                    }
                  ]
                },
                {
                  "type": "block_quote",
                  "children": [
                    {
                      "text": "For detailed information:",
                      "bold": true
                    }
                  ]
                },
                {
                  "type": "paragraph",
                  "children": [
                    {
                      "text": "•\tPlease refer WIDUSHI Guidelines at "
                    },
                    {
                      "type": "link",
                      "link": "https://dst.gov.in/",
                      "children": [
                        {
                          "text": "www.dst.gov.in"
                        }
                      ]
                    },
                    {
                      "text": " and "
                    },
                    {
