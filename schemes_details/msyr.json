      "applicationProcess": [
        {
          "mode": "Offline",
          "process": [
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 1:",
                  "bold": true
                },
                {
                  "text": " Interested voluntary organizations must submit applications in the prescribed format to the District Collector’s Office. "
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 2:",
                  "bold": true
                },
                {
                  "text": " The District Collector’s office reviews and recommends the application."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 3:",
                  "bold": true
                },
                {
                  "text": " The Social Justice and Empowerment Department evaluates the application."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 4:",
                  "bold": true
                },
                {
                  "text": " Eligible organizations receive approval and funding."
                }
              ]
            },
            {
              "type": "paragraph",
              "children": [
                {
                  "text": "Step 5:",
                  "bold": true
                },
                {
                  "text": " Beneficiary women enroll through the Admission Advisory Committee."
                }
              ]
            }
          ],
          "process_md": "**Step 1:** Interested voluntary organizations must submit applications in the prescribed format to the District Collector’s Office. \n**Step 2:** The District Collector’s office reviews and recommends the application.\n**Step 3:** The Social Justice and Empowerment Department evaluates the application.\n**Step 4:** Eligible organizations receive approval and funding.\n**Step 5:** Beneficiary women enroll through the Admission Advisory Committee.\n"
        }
      ],
      "schemeDefinitions": [],
      "eligibilityCriteria": {
        "eligibilityDescription_md": "\n1. The applicant should be a registered voluntary organization, trust, or NGO.\n1. The organization must be operational for at least three years before applying.\n1. The organization should be non-profit and focused on women’s welfare.\n1. The organization must have a formally structured administrative and management committee.\n1. The organization should not be blacklisted or penalized by any government department.\n\n",
